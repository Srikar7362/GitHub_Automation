# Copy this file to ".env" and fill in your real values.
# The .env file is git-ignored and must never be committed.

# Required: GitHub Personal Access Token with the "repo" scope.
# See README.md -> "API key setup" for how to create one.
GITHUB_TOKEN=your_personal_access_token_here

# Optional: only needed if you enable external AI idea generation in
# config.json (project_creator_agent.external_ai.enabled = true).
# HUGGINGFACE_API_TOKEN=your_huggingface_token_here
